---
import { SITE } from "../consts";
const base = import.meta.env.BASE_URL; // GH Pages /blog/，本地 /
---
<section class="hero">
  <div class="container">
    <span class="eyebrow">✦ AI · 技术 · 笔记</span>
    <h1>{SITE.title} <span class="gradient-text">· {SITE.tagline}</span></h1>
    <p class="lead">{SITE.description}</p>
    <div class="cta">
      <a class="btn btn-primary" href="#posts">浏览文章 →</a>
      <a class="btn btn-ghost" href={`${base}about`}>关于我</a>
    </div>
  </div>
</section>
