---
const { post, index = 0 } = Astro.props;
const { title, description, date, tags, emoji, cover, category } = post.data;
const slug = post.slug;
const base = import.meta.env.BASE_URL; // GH Pages /blog/，本地 /
const asset = (p: string) => base + p.replace(/^\//, "");
const fmtDate = new Date(date).toLocaleDateString("zh-CN", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
const alt = index % 2 === 1;
const tagClass = ["", "violet", "cyan"];
---
<a
  class="card post-card"
  href={`${base}posts/${slug}`}
  data-slug={slug}
  data-category={category.toLowerCase()}
  data-title={title.toLowerCase()}
  data-desc={description.toLowerCase()}
  data-tags={tags.join(" ").toLowerCase()}
>
  <div class={`cover ${alt ? "alt" : ""}`}>
    {cover ? <img src={asset(cover)} alt={title} /> : <span>{emoji}</span>}
  </div>
  <div class="body">
    <div class="meta"><span>📅 {fmtDate}</span></div>
    <h3>{title}</h3>
    <p class="excerpt">{description}</p>
    <div class="tags">
      {tags.slice(0, 3).map((t, i) => (
        <span class={`tag ${tagClass[i % 3]}`}>{t}</span>
      ))}
    </div>
  </div>
</a>
