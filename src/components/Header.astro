---
import { SITE, NAV } from "../consts";
import { LANGS, DEFAULT_LANG, t } from "../i18n/ui";
const base = import.meta.env.BASE_URL; // GH Pages /blog/，本地 /
const path = Astro.url.pathname;
const normPath = (path.startsWith(base) ? path.slice(base.length - 1) : path) || "/";
const fullHref = (h: string) => base + h.replace(/^\//, "");
const curLang = LANGS.find((l) => l.code === DEFAULT_LANG)!;

// 主题定义（与 site-controls.ts 保持一致）
const DEFAULT_THEME = "cute";
type ThemeDef = { code: string; icon: string };
const THEMES: ThemeDef[] = [
  { code: "neon", icon: "◆" },
  { code: "cute", icon: "🌸" },
  { code: "pretty", icon: "💐" },
  { code: "cool", icon: "🌌" },
];
const RANDOM_ICON = "🎲";
const themeDict = t[DEFAULT_LANG];
const curTheme = THEMES.find((x) => x.code === DEFAULT_THEME)!;
const themeLabel = (code: string) => themeDict["theme." + code] || code;
---
<header class="site-header" id="siteHeader">
  <div class="container inner">
    <a class="brand" href={base}>
      <span class="logo">◆</span>
      <span data-i18n="site.title">{SITE.title}</span>
    </a>
    <button class="nav-toggle" id="navToggle" data-i18n-attr="aria-label:nav.menu" aria-label="打开菜单">
      <span></span><span></span><span></span>
    </button>
    <div class="nav-right">
      <nav class="nav">
        {NAV.map((item) => (
          <a href={fullHref(item.href)} class={normPath === item.href ? "active" : ""} data-i18n={item.key}>{item.label}</a>
        ))}
      </nav>
      <a class="nav-github" href="https://github.com/id189/blog" target="_blank" rel="noopener noreferrer" aria-label="GitHub 仓库" title="GitHub" data-i18n-attr="aria-label:nav.github|title:nav.github">
        <svg viewBox="0 0 16 16" aria-hidden="true" focusable="false">
          <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.65-3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0 0 16 8c0-4.42-3.58-8-8-8z"></path>
        </svg>
      </a>
      <div class="nav-controls">
        <div class="lang-switch">
          <button type="button" class="ctrl-btn lang-btn" id="langBtn" data-i18n-attr="aria-label:lang.aria" aria-label="切换语言">
            <span class="lang-cur">{curLang.flag} {curLang.label}</span>
            <span class="caret">▾</span>
          </button>
          <div class="lang-menu" id="langMenu">
            {LANGS.map((l) => (
              <button type="button" class="lang-opt" data-lang={l.code}>
                <span class="flag">{l.flag}</span><span class="nm">{l.label}</span>
              </button>
            ))}
          </div>
        </div>
        <div class="theme-switch">
          <button type="button" class="ctrl-btn theme-btn" id="themeBtn" data-i18n-attr="aria-label:theme.aria" aria-label="切换主题" aria-haspopup="true" aria-expanded="false">
            <span class="theme-cur">{curTheme.icon} {themeLabel(curTheme.code)}</span>
            <span class="caret">▾</span>
          </button>
          <div class="theme-menu" id="themeMenu" role="menu">
            {THEMES.map((th) => (
              <button type="button" class="theme-opt" data-theme={th.code} role="menuitem">
                <span class="ico">{th.icon}</span><span class="nm">{themeLabel(th.code)}</span>
              </button>
            ))}
            <button type="button" class="theme-opt" data-theme="random" role="menuitem">
              <span class="ico">{RANDOM_ICON}</span><span class="nm" data-i18n="theme.random">随机</span>
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</header>

<style>
  .nav-toggle { display: none; flex-direction: column; gap: 5px; background: none; border: none; cursor: pointer; padding: 8px; }
  .nav-toggle span { width: 22px; height: 2px; background: var(--ink); border-radius: 2px; display: block; transition: transform 0.2s; }
  @media (max-width: 720px) {
    .nav-toggle { display: inline-flex; }
  }
</style>

<script>
  const btn = document.getElementById("navToggle");
  const header = document.getElementById("siteHeader");
  btn?.addEventListener("click", () => header?.classList.toggle("nav-open"));
</script>
