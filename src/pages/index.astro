---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";
import Hero from "../components/Hero.astro";
import PostCard from "../components/PostCard.astro";

const posts = (await getCollection("posts", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

// 标签词频（用于右侧标签云；保留原始大小写用于展示，筛选时统一转小写匹配）
const tagFreq = new Map<string, number>();
for (const p of posts) {
  for (const t of (p.data.tags || [])) {
    tagFreq.set(t, (tagFreq.get(t) ?? 0) + 1);
  }
}
const topTags = [...tagFreq.entries()]
  .sort((a, b) => b[1] - a[1])
  .map(([tag, count]) => ({ tag, count }));
---

<Base title="">
  <Hero />
  <section class="section" id="posts">
    <div class="container home-container">
      <div class="section-head">
        <h2 data-i18n="index.latest">最新文章</h2>
        <span class="muted" id="resultCount" data-i18n="index.count" data-count={posts.length}>{posts.length} 篇 · 持续更新中</span>
      </div>

      <div class="home-layout">
        <div class="posts-grid">
          {posts.map((post, i) => <PostCard post={post} index={i} />)}
        </div>

        <aside class="side-col">
          <div class="card search-box">
            <span class="ico">🔍</span>
            <input
              id="siteSearch"
              type="search"
              placeholder="搜索文章…"
              autocomplete="off"
              aria-label="站内搜索"
              data-i18n-attr="placeholder:index.searchPh|aria-label:index.searchAria"
            />
          </div>

          <div class="card cat-list">
            <h4 data-i18n="index.category">分类</h4>
            <button type="button" class="cat-item active" id="catAll" data-cat-path=""><span class="name" data-i18n="index.all">全部</span><span class="count">{posts.length}</span></button>
            <div class="cat-tree" id="catTree"></div>
          </div>

          <div class="card tag-cloud-card">
            <h4 data-i18n="index.tag">标签</h4>
            <div class="tag-cloud" id="tagCloud"></div>
          </div>
        </aside>
      </div>

      <p class="no-result" id="noResult" data-i18n="index.noResult" hidden>没有匹配的文章，换个关键词试试～</p>
    </div>
  </section>
</Base>

<script define:vars={{ topTags, BASE: import.meta.env.BASE_URL, IS_PROD: import.meta.env.PROD }}>
  const grid = document.querySelector(".posts-grid");
  const cards = Array.from(document.querySelectorAll(".post-card"));
  const searchInput = document.querySelector("#siteSearch");
  const catAllBtn = document.getElementById("catAll");
  const catTree = document.getElementById("catTree");
  const tagCloud = document.getElementById("tagCloud");
  const resultCount = document.querySelector("#resultCount");
  const noResult = document.querySelector("#noResult");
  if (!grid || !searchInput || !resultCount || !noResult) {
    // 元素不存在时直接退出（非首页）
  } else {
    let activeCatPath = null;   // null = 全部
    let matchedSlugs = null;    // null = 未搜索（全部匹配）
    let pf = null;
    let pfReady = false;
    const selectedTags = new Set();
    const catLoaded = new Map();

    // 尝试加载 Pagefind（仅构建产物中存在；dev 下失败则降级为 data-* 文本匹配）
    (async () => {
      if (!IS_PROD) {
        pfReady = false;
        return;
      }
      try {
        const pfUrl = `${BASE}pagefind/pagefind.js`;
        pf = await import(/* @vite-ignore */ pfUrl);
        if (pf && typeof pf.init === "function") {
          await pf.init({ basePath: `${BASE}pagefind/` });
        }
        pfReady = true;
      } catch {
        pfReady = false;
      }
    })();

    const normUrl = (u) => u.replace(/\/index\.html$/, "").replace(/\/+$/, "");

    // 三条件 AND：选中分类子树 ∩ 选中标签 ∩ 搜索命中
    function applyFilter() {
      let visible = 0;
      for (const card of cards) {
        const postCat = card.dataset.category ?? "";
        const slug = card.dataset.slug ?? "";
        const cardTags = new Set((card.dataset.tags ?? "").split(" ").filter(Boolean));
        const catOk =
          activeCatPath === null ||
          postCat === activeCatPath ||
          postCat.startsWith(activeCatPath + "/");
        const tagsOk = selectedTags.size === 0 || [...selectedTags].every((t) => cardTags.has(t));
        const searchOk = matchedSlugs === null || matchedSlugs.has(slug);
        const show = catOk && tagsOk && searchOk;
        card.style.display = show ? "" : "none";
        if (show) visible++;
      }
      resultCount.dataset.count = String(visible);
      resultCount.textContent = window.__fmtCount ? window.__fmtCount(visible) : (visible + " 篇 · 持续更新中");
      noResult.hidden = visible !== 0;
    }

    // ── 分类树（懒加载：初次仅请求顶级，展开时再 fetch 子级）──
    async function loadChildren(id) {
      if (catLoaded.has(id)) return catLoaded.get(id);
      const res = await fetch(`${BASE}api/categories/${id}.json`);
      const data = await res.json();
      const children = data.children || [];
      catLoaded.set(id, children);
      return children;
    }

    function makeNode(child, depth) {
      const row = document.createElement("div");
      row.className = "cat-node";

      const toggle = document.createElement("span");
      toggle.className = "toggle";
      toggle.textContent = child.hasChildren ? "▸" : "";
      toggle.style.visibility = child.hasChildren ? "visible" : "hidden";

      const label = document.createElement("button");
      label.type = "button";
      label.className = "cat-label";
      label.dataset.catPath = child.path;
      label.innerHTML = `<span class="name">${child.name}</span><span class="count">${child.postCount}</span>`;
      label.addEventListener("click", () => {
        document.querySelectorAll(".cat-label.selected").forEach((el) => el.classList.remove("selected"));
        label.classList.add("selected");
        catAllBtn?.classList.remove("active");
        activeCatPath = child.path === "" ? null : child.path;
        applyFilter();
      });

      if (child.hasChildren) {
        let expanded = false;
        const box = document.createElement("div");
        box.className = "cat-children";
        box.hidden = true;
        toggle.addEventListener("click", async (e) => {
          e.stopPropagation();
          if (!expanded) {
            toggle.textContent = "▾";
            if (!box.childElementCount) {
              const kids = await loadChildren(child.id);
              kids.forEach((k) => box.appendChild(makeNode(k, depth + 1)));
            }
            box.hidden = false;
          } else {
            toggle.textContent = "▸";
            box.hidden = true;
          }
          expanded = !expanded;
        });
        row.append(toggle, label, box);
      } else {
        row.append(toggle, label);
      }
      return row;
    }

    if (catTree) {
      loadChildren("root")
        .then((children) => {
          children.forEach((c) => catTree.appendChild(makeNode(c, 0)));
        })
        .catch((err) => {
          console.error("[cat-tree] 加载失败:", err);
        });
    }

    catAllBtn?.addEventListener("click", () => {
      activeCatPath = null;
      document.querySelectorAll(".cat-label.selected").forEach((el) => el.classList.remove("selected"));
      catAllBtn.classList.add("active");
      applyFilter();
    });

    // ── 标签云（多选，与分类/搜索取交集）──
    if (tagCloud && Array.isArray(topTags)) {
      const max = Math.max(1, ...topTags.map((t) => t.count));
      topTags.forEach(({ tag, count }) => {
        const btn = document.createElement("button");
        btn.type = "button";
        btn.className = "tag-chip";
        btn.dataset.tag = tag.toLowerCase();
        btn.style.fontSize = `${0.78 + 0.34 * (count / max)}rem`;
        btn.innerHTML = `${tag} <span class="count">${count}</span>`;
        btn.addEventListener("click", () => {
          const key = tag.toLowerCase();
          if (selectedTags.has(key)) {
            selectedTags.delete(key);
            btn.classList.remove("active");
          } else {
            selectedTags.add(key);
            btn.classList.add("active");
          }
          applyFilter();
        });
        tagCloud.appendChild(btn);
      });
    }

    // ── 搜索（防抖）──
    let timer;
    searchInput.addEventListener("input", () => {
      const term = searchInput.value.trim().toLowerCase();
      window.clearTimeout(timer);
      timer = window.setTimeout(async () => {
        if (term === "") {
          matchedSlugs = null;
          applyFilter();
          return;
        }
        if (pfReady && pf) {
          try {
            const res = await pf.search(term);
            const top = res.results.slice(0, 50);
            const data = await Promise.all(top.map((r) => r.data()));
            matchedSlugs = new Set(
              data.map((d) => {
                const slug = normUrl(d.url).split("/").filter(Boolean).pop() ?? "";
                return slug;
              })
            );
            applyFilter();
            return;
          } catch {
            // 落到降级逻辑
          }
        }
        // 降级：基于标题/描述/标签/分类文本匹配
        matchedSlugs = new Set(
          cards
            .filter((c) => {
              const hay = `${c.dataset.title} ${c.dataset.desc} ${c.dataset.tags} ${c.dataset.category}`.toLowerCase();
              return hay.includes(term);
            })
            .map((c) => c.dataset.slug ?? "")
        );
        applyFilter();
      }, 200);
    });
  }
</script>
