---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";
import Hero from "../components/Hero.astro";
import PostCard from "../components/PostCard.astro";

const posts = (await getCollection("posts", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

// 统计分类及篇数
const counts = new Map<string, number>();
for (const p of posts) {
  const c = p.data.category || "未分类";
  counts.set(c, (counts.get(c) ?? 0) + 1);
}
const categories = [...counts.entries()].sort((a, b) => b[1] - a[1]);
---

<Base title="">
  <Hero />
  <section class="section" id="posts">
    <div class="container home-container">
      <div class="section-head">
        <h2>最新文章</h2>
        <span class="muted" id="resultCount">{posts.length} 篇 · 持续更新中</span>
      </div>

      <div class="home-layout">
        <div class="posts-grid">
          {posts.map((post, i) => <PostCard post={post} index={i} />)}
        </div>

        <aside class="side-col">
          <div class="card search-box">
            <span class="ico">🔍</span>
            <input
              id="siteSearch"
              type="search"
              placeholder="搜索文章…"
              autocomplete="off"
              aria-label="站内搜索"
            />
          </div>

          <div class="card cat-list">
            <h4>分类</h4>
            <button type="button" class="cat-item active" data-cat="">全部 <span class="count">{posts.length}</span></button>
            {
              categories.map(([c, n]) => (
                <button type="button" class="cat-item" data-cat={c}>
                  {c} <span class="count">{n}</span>
                </button>
              ))
            }
          </div>
        </aside>
      </div>

      <p class="no-result" id="noResult" hidden>没有匹配的文章，换个关键词试试～</p>
    </div>
  </section>
</Base>

<script>
  const grid = document.querySelector<HTMLElement>(".posts-grid");
  const cards = Array.from(document.querySelectorAll<HTMLElement>(".post-card"));
  const searchInput = document.querySelector<HTMLInputElement>("#siteSearch");
  const catItems = Array.from(document.querySelectorAll<HTMLElement>(".cat-item"));
  const resultCount = document.querySelector<HTMLElement>("#resultCount");
  const noResult = document.querySelector<HTMLElement>("#noResult");
  if (!grid || !searchInput || !resultCount || !noResult) {
    // 元素不存在时直接退出（非首页）
  } else {
    let activeCat: string | null = null;
    let matchedSlugs: Set<string> | null = null; // null = 未搜索（全部匹配）
    let pf: any = null;
    let pfReady = false;

    // 尝试加载 Pagefind（仅构建产物中存在；dev 下失败则降级）
    (async () => {
      try {
        const pfUrl = "/pagefind/pagefind.js";
        pf = await import(/* @vite-ignore */ pfUrl);
        if (pf && typeof pf.init === "function") await pf.init();
        pfReady = true;
      } catch {
        pfReady = false;
      }
    })();

    const normUrl = (u: string) => u.replace(/\/index\.html$/, "").replace(/\/+$/, "");

    function applyFilter() {
      let visible = 0;
      for (const card of cards) {
        const cat = card.dataset.category ?? "";
        const slug = card.dataset.slug ?? "";
        const catOk = activeCat === null || cat === activeCat;
        const searchOk = matchedSlugs === null || matchedSlugs.has(slug);
        const show = catOk && searchOk;
        card.style.display = show ? "" : "none";
        if (show) visible++;
      }
      resultCount.textContent = `${visible} 篇 · 持续更新中`;
      noResult.hidden = visible !== 0;
    }

    // 分类点击
    catItems.forEach((btn) => {
      btn.addEventListener("click", () => {
        catItems.forEach((b) => b.classList.remove("active"));
        btn.classList.add("active");
        const c = btn.dataset.cat ?? "";
        activeCat = c === "" ? null : c;
        applyFilter();
      });
    });

    // 搜索（防抖）
    let timer: number | undefined;
    searchInput.addEventListener("input", () => {
      const term = searchInput.value.trim().toLowerCase();
      window.clearTimeout(timer);
      timer = window.setTimeout(async () => {
        if (term === "") {
          matchedSlugs = null;
          applyFilter();
          return;
        }
        if (pfReady && pf) {
          try {
            const res = await pf.search(term);
            const top = res.results.slice(0, 50);
            const data = await Promise.all(top.map((r: any) => r.data()));
            matchedSlugs = new Set(
              data.map((d: any) => {
                const slug = normUrl(d.url).split("/").filter(Boolean).pop() ?? "";
                return slug;
              })
            );
            applyFilter();
            return;
          } catch {
            // 落到降级逻辑
          }
        }
        // 降级：基于标题/描述/标签/分类文本匹配
        matchedSlugs = new Set(
          cards
            .filter((c) => {
              const hay = `${c.dataset.title} ${c.dataset.desc} ${c.dataset.tags} ${c.dataset.category}`.toLowerCase();
              return hay.includes(term);
            })
            .map((c) => c.dataset.slug ?? "")
        );
        applyFilter();
      }, 200);
    });
  }
</script>
