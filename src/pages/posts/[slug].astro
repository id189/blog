---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import Toc from "../../components/Toc.astro";

export async function getStaticPaths() {
  const posts = await getCollection("posts", ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await post.render();
const { title, description, date, tags, author, cover } = post.data;
const base = import.meta.env.BASE_URL; // GH Pages /blog/，本地 /
const asset = (p: string) => base + p.replace(/^\//, "");
const fmtDate = new Date(date).toLocaleDateString("zh-CN", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
const iso = new Date(date).toISOString();
---
<Base title={title} description={description}>
  <article class="section">
    <div class="container post-layout">
      <div>
        <div class="article-head">
          <div class="article-meta">
            <span>📅 <time data-iso={iso}>{fmtDate}</time></span>
            <span>✍️ {author}</span>
            {tags.map((t) => <span class="tag">{t}</span>)}
          </div>
          <h1>{title}</h1>
          <p class="muted">{description}</p>
        </div>
        {cover && (
          <img
            src={asset(cover)}
            alt={title}
            class="post-cover"
            style="width:100%;height:auto;border-radius:16px;margin:0 0 28px;display:block;box-shadow:0 8px 30px rgba(0,0,0,.08);"
          />
        )}
        <div class="prose">
          <Content />
        </div>
        <div style="margin-top:40px">
          <a class="btn btn-ghost" href={base} data-i18n="post.back">← 返回首页</a>
        </div>
      </div>
      <aside class="toc">
        <Toc headings={headings} />
      </aside>
    </div>
  </article>
</Base>
