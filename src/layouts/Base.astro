---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import GlowOrb from "../components/GlowOrb.astro";
import { SITE } from "../consts";

const base = import.meta.env.BASE_URL; // GH Pages 子路径 /blog/，本地为 /
const { title, description = SITE.description, titleKey = "" } = Astro.props;
const fullTitle = title ? `${title} · ${SITE.title}` : `${SITE.title} · ${SITE.tagline}`;
const tpl = title ? "{page} · {site.title}" : "{site.title} · {site.tagline}";
// 默认描述（= SITE.description）随语言切换；文章页传入自己的 description 则不翻译
const descKey = description === SITE.description ? "site.description" : "";
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} data-desc-key={descKey} />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <title data-tpl={tpl} data-page={title || ""} data-page-key={titleKey}>{fullTitle}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&family=Sora:wght@600;700&family=Inter:wght@400;500;600&family=Noto+Sans+SC:wght@400;500;700&family=JetBrains+Mono:wght@400;500&family=Baloo+2:wght@500;600;700&family=Nunito:wght@400;600;700&family=Playfair+Display:wght@600;700&family=Noto+Serif+SC:wght@600;700&family=Orbitron:wght@600;700&display=swap"
      rel="stylesheet"
    />

    {/* 防 FOUC：渲染前同步读取 localStorage 设置主题 */}
    <script is:inline>
      (function () {
        try {
          var t = localStorage.getItem("theme") || "neon";
          document.documentElement.dataset.theme = t;
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <GlowOrb />
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>

<script>
  import "../scripts/site-controls";
</script>
